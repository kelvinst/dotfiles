#!/bin/sh
# orbit — our aerospace wrapper with more commands

set -eu

# Detach stdin from whatever the caller inherited. Without this, aerospace
# CLI subcommands read stdin by default to batch further commands — when
# orbit is launched by something like vim's `jobstart` (stdin = open pipe,
# never written), aerospace blocks forever. Symptom: dozens of stuck
# `aerospace focus`/`workspace` processes piling up on repeated keypresses
# until the GUI server chokes.
exec </dev/null

cmd_help() {
  cat <<'EOF'
orbit — aerospace helper.

Usage: orbit <command> [args...]

Commands:
  open     Focus or spawn an app window by bundle-id.

  focus    A wrapper around `aerospace focus` that adds more options to it.

  move     A wrapper around `aerospace move` that adds more options to it.

  swap     A wrapper around `aerospace swap`: falls back to `move` in
           accordion layouts where swap is equivalent but buggier.

  swap-or-move-node-to-workspace
           Swap the focused window with its neighbor; at the workspace edge,
           move the window to the adjacent workspace instead.

  move-workspace
           Move the focused workspace to another position. If the target
           position is already occupied, the two workspaces swap places
           (windows + root layout). Pass `--focus-follows-workspace` to
           land focus on the target.

  preset   Arrange the focused workspace into a predefined layout.

  move-workspace-to-secondary-monitor
           Pin the given workspaces to the secondary monitor, flatten them,
           and set them to accordion.

  force-restart
           Kill every aerospace process (GUI server + any stuck CLI calls)
           and relaunch AeroSpace. Use when the server stops responding.

  cleanup  Kill stuck `aerospace` CLI processes while leaving the GUI
           server running.

  help     Show this help.

Run `orbit <command> help` for details on a command.

Any other command is forwarded to `aerospace` verbatim, so
`orbit reload-config` runs `aerospace reload-config`.
EOF
}

cmd_open_help() {
  cat <<'EOF'
Usage: orbit open [-g|--global] [-p|--pull] <bundle-id>

Focus an app window in the focused aerospace workspace, or spawn a new
window here.

Options:
  -g, --global  Focus an existing window in any workspace.
  -p, --pull    If an existing window lives in another workspace, move it
                to the focused workspace before focusing. Implies --global
                (a global search is needed either way).
EOF
}

cmd_focus_help() {
  cat <<'EOF'
Usage: orbit focus dfs-first
       orbit focus dfs-last
       orbit focus [args...]

A wrapper around `aerospace focus` that adds more options to it.

Added options:
  --boundaries-action sibling-workspace
        On horizontal focus failure, focus the adjacent workspace
        instead (right → next, left → prev). Only applies to
        left/right — up/down just fail at the boundary.

Added subcommands:
  dfs-first   Focus the first window (`--dfs-index 0`).
  dfs-last    Focus the last window on the focused workspace.
EOF
}

cmd_move_help() {
  cat <<'EOF'
Usage: orbit move [args...]

A wrapper around `aerospace move` that adds more options to it.

Added options:
  --boundaries-action sibling-workspace
        On horizontal move failure, move the window to the adjacent
        workspace instead (right → next, left → prev). Only applies
        to left/right — up/down just fail at the boundary.
EOF
}

cmd_swap_help() {
  cat <<'EOF'
Usage: orbit swap [args...]

A wrapper around `aerospace swap`. In accordion layouts, `aerospace swap` is
essentially the same as `aerospace move` but behaves strangely, so fall back
to `aerospace move` in that case.
EOF
}

cmd_swap_or_move_help() {
  cat <<'EOF'
Usage: orbit swap-or-move-node-to-workspace [args...] <direction>

Run `orbit swap` (without `--wrap-around`) with the given args. If the swap
fails because the window is at the workspace boundary, fall back to
`orbit move --boundaries-action sibling-workspace <direction>` so the window
is sent to the adjacent workspace instead.
EOF
}

cmd_move_workspace_help() {
  cat <<'EOF'
Usage: orbit move-workspace [--focus-follows-workspace] <target-workspace>

Move the focused workspace to another position. If there's already a
workspace at <target-workspace>, that workspace swaps positions with
this one — windows and root layout cross over, so e.g. a `tiles`
workspace traded with an `accordion` one keeps each layout traveling
with its windows. No-op when the focused workspace is already
<target-workspace>.

Options:
  --focus-follows-workspace
        Focus <target-workspace> after the move. Without this flag focus
        stays on the current workspace (which now holds the other
        workspace's contents).
EOF
}

cmd_preset_help() {
  cat <<'EOF'
Usage: orbit preset [options] <preset-name>

Arrange the focused workspace into a predefined layout. The focused window
becomes the "main" window of the preset.

Options:
  --main-size <delta>   Resize the main window by <delta> along the preset's
                        main dimension — width for column presets, height
                        for row presets (e.g. `+150`, `-50`).

Presets:
  2-col-left    Main window on the left, remaining windows stacked
                vertically in a single column on the right.
  2-col-right   Main window on the right, remaining windows stacked
                vertically in a single column on the left.
  2-row-top     Main window on top, remaining windows side-by-side
                in a single row below.
  2-row-bottom  Main window on the bottom, remaining windows side-by-side
                in a single row above.
  3-col-left    Main window on the left, remaining windows split between
                two columns on the right, each stacked vertically.
  3-col-middle  Main window in the middle column, remaining windows split
                between a column on the left and a column on the right,
                each stacked vertically.
  3-col-right   Main window on the right, remaining windows split between
                two columns on the left, each stacked vertically.
  3-row-top     Main window on top, remaining windows split between two
                rows below, each tiled horizontally.
  3-row-middle  Main window in the middle row, remaining windows split
                between a row above and a row below, each tiled
                horizontally.
  3-row-bottom  Main window on the bottom, remaining windows split between
                two rows above, each tiled horizontally.
EOF
}

cmd_open() {
  case "${1:-}" in
  help | -h | --help)
    cmd_open_help
    return
    ;;
  esac

  any_workspace=0
  pull=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
    -g | --global)
      any_workspace=1
      shift
      ;;
    -p | --pull)
      pull=1
      shift
      ;;
    -*)
      echo "orbit open: unknown option '$1'" >&2
      cmd_open_help >&2
      return 2
      ;;
    *)
      break
      ;;
    esac
  done

  # --pull implies global search: we have to find the window anywhere to
  # decide whether it's worth pulling. Harmless if -g is already set.
  [ "$pull" -eq 1 ] && any_workspace=1

  bundle_id="$1"

  if [ "$any_workspace" -eq 1 ]; then
    window_id=$(aerospace list-windows --all --format '%{window-id} %{app-bundle-id}' 2>/dev/null |
      awk -v id="$bundle_id" '$2 == id {print $1; exit}')
  else
    window_id=$(aerospace list-windows --workspace focused --app-bundle-id "$bundle_id" --format '%{window-id}' 2>/dev/null | head -n1)
  fi

  if [ -n "$window_id" ]; then
    if [ "$pull" -eq 1 ]; then
      current_ws=$(aerospace list-workspaces --focused)
      # Look up the window's workspace so we can skip a no-op move when
      # it's already on the focused workspace — aerospace rejects moving
      # a node to the workspace it already lives in.
      window_ws=$(aerospace list-windows --all --format '%{window-id} %{workspace}' 2>/dev/null |
        awk -v id="$window_id" '$1 == id {print $2; exit}')
      if [ -n "$window_ws" ] && [ "$window_ws" != "$current_ws" ]; then
        aerospace move-node-to-workspace --window-id "$window_id" "$current_ws" 2>/dev/null || :
      fi
    fi
    aerospace focus --window-id "$window_id"
  elif [ "$bundle_id" = "com.apple.finder" ]; then
    osascript -e 'tell application "Finder"
                      make new Finder window
                      activate
                  end tell'
  elif [ "$bundle_id" = "net.kovidgoyal.kitty" ]; then
    socket=$(ls -t /tmp/kitty-* 2>/dev/null | head -n1)
    kitten @ --to "unix:$socket" launch --type=os-window >/dev/null
  elif osascript -e "tell application id \"$bundle_id\" to make new window" >/dev/null 2>&1; then
    osascript -e "tell application id \"$bundle_id\" to activate"
  else
    open -nb "$bundle_id"
  fi
}

cmd_focus() {
  case "${1:-}" in
  help | -h | --help)
    cmd_focus_help
    return
    ;;
  dfs-first)
    aerospace focus --dfs-index 0
    return
    ;;
  dfs-last)
    last=$(($(aerospace list-windows --workspace focused --format '%{window-id}' | wc -l) - 1))
    aerospace focus --dfs-index "$last"
    return
    ;;
  esac

  # Extend `aerospace focus` with a custom `--boundaries-action
  # sibling-workspace` value: strip that flag and, on focus failure,
  # switch to the adjacent workspace (right/down → next, left/up → prev).
  # Any other invocation is forwarded verbatim.
  sibling=0
  count=$#
  idx=0
  while [ "$idx" -lt "$count" ]; do
    if [ "$1" = "--boundaries-action" ] && [ "${2:-}" = "sibling-workspace" ]; then
      sibling=1
      shift 2
      idx=$((idx + 2))
      continue
    fi
    arg="$1"
    shift
    set -- "$@" "$arg"
    idx=$((idx + 1))
  done

  if [ "$sibling" -eq 0 ]; then
    exec aerospace focus "$@"
  fi

  # `--boundaries all-monitors-outer-frame` would let focus cross monitors at
  # the workspace edge, so the boundary never fails and the sibling-workspace
  # fallback never fires. Reject the combination explicitly.
  prev=""
  for arg in "$@"; do
    if [ "$prev" = "--boundaries" ] && [ "$arg" = "all-monitors-outer-frame" ]; then
      echo "orbit focus: --boundaries all-monitors-outer-frame is incompatible with --boundaries-action sibling-workspace" >&2
      return 2
    fi
    prev="$arg"
  done

  if aerospace focus --boundaries-action fail "$@" 2>/dev/null; then
    return
  fi
  direction=""
  for arg in "$@"; do direction="$arg"; done
  case "$direction" in
  right)
    aerospace workspace --wrap-around --no-stdin next
    cmd_focus dfs-first
    ;;
  left)
    aerospace workspace --wrap-around --no-stdin prev
    cmd_focus dfs-last
    ;;
  *) return 1 ;;
  esac
}

cmd_move() {
  case "${1:-}" in
  help | -h | --help)
    cmd_move_help
    return
    ;;
  esac

  # Extend `aerospace move` with a custom `--boundaries-action
  # sibling-workspace` value: strip that flag and, on horizontal move
  # failure, send the window to the adjacent workspace (right → next,
  # left → prev). up/down fall through to the default fail behavior.
  # Any other invocation is forwarded verbatim.
  sibling=0
  count=$#
  idx=0
  while [ "$idx" -lt "$count" ]; do
    if [ "$1" = "--boundaries-action" ] && [ "${2:-}" = "sibling-workspace" ]; then
      sibling=1
      shift 2
      idx=$((idx + 2))
      continue
    fi
    arg="$1"
    shift
    set -- "$@" "$arg"
    idx=$((idx + 1))
  done

  if [ "$sibling" -eq 0 ]; then
    exec aerospace move "$@"
  fi

  # `--boundaries all-monitors-outer-frame` would let move cross monitors at
  # the workspace edge, so the boundary never fails and the sibling-workspace
  # fallback never fires. Reject the combination explicitly.
  prev=""
  for arg in "$@"; do
    if [ "$prev" = "--boundaries" ] && [ "$arg" = "all-monitors-outer-frame" ]; then
      echo "orbit move: --boundaries all-monitors-outer-frame is incompatible with --boundaries-action sibling-workspace" >&2
      return 2
    fi
    prev="$arg"
  done

  if aerospace move --boundaries-action fail "$@" 2>/dev/null; then
    return
  fi
  direction=""
  for arg in "$@"; do direction="$arg"; done
  case "$direction" in
  right)
    aerospace move-node-to-workspace --wrap-around --focus-follows-window --no-stdin next
    while aerospace move --boundaries-action fail left 2>/dev/null; do :; done
    ;;
  left)
    aerospace move-node-to-workspace --wrap-around --focus-follows-window --no-stdin prev
    while aerospace move --boundaries-action fail right 2>/dev/null; do :; done
    ;;
  *) return 1 ;;
  esac
}

cmd_swap() {
  case "${1:-}" in
  help | -h | --help)
    cmd_swap_help
    return
    ;;
  esac

  layout=$(aerospace list-windows --focused --format '%{window-parent-container-layout}')
  case "$layout" in
  *accordion*) aerospace move "$@" ;;
  *) aerospace swap "$@" ;;
  esac
}

cmd_swap_or_move() {
  case "${1:-}" in
  help | -h | --help)
    cmd_swap_or_move_help
    return
    ;;
  esac

  if cmd_swap "$@" 2>/dev/null; then
    return
  fi
  direction=""
  for arg in "$@"; do direction="$arg"; done
  cmd_move --boundaries-action sibling-workspace "$direction"
}

cmd_move_workspace() {
  case "${1:-}" in
  help | -h | --help | "")
    cmd_move_workspace_help
    return
    ;;
  esac

  focus_follows=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
    --focus-follows-workspace)
      focus_follows=1
      shift
      ;;
    -*)
      echo "orbit move-workspace: unknown option '$1'" >&2
      cmd_move_workspace_help >&2
      return 2
      ;;
    *)
      break
      ;;
    esac
  done

  # Serialize invocations: while a previous `move-workspace` is still in
  # flight (splash focused, windows mid-hop), a second keypress would read
  # `splash` as its source and scramble state. `mkdir` is atomic across
  # processes, so it's a safe no-deps mutex. If a run dies before the
  # trap releases the lock (e.g. SIGKILL), `rmdir` it manually.
  lockdir="/tmp/orbit-move-workspace.$(id -u).lock"
  if ! mkdir "$lockdir" 2>/dev/null; then
    return 0
  fi

  # `restore_on_exit` / `restore_window_on_exit` together with the trap
  # guarantee focus never gets stuck on splash: even if `set -e` kills
  # orbit mid-swap (e.g. a move targets a window that just closed), the
  # trap still fires and sends focus somewhere real. Both start empty so
  # the early-return paths below (before any splash focus) don't trigger
  # an unnecessary workspace jump. For --focus-follows-workspace we set
  # the window-id only — `aerospace focus --window-id` carries its
  # workspace forward, no need to focus the workspace separately.
  restore_on_exit=""
  restore_window_on_exit=""
  trap '
    if [ -n "$restore_window_on_exit" ]; then
      aerospace focus --window-id "$restore_window_on_exit" 2>/dev/null || :
    elif [ -n "$restore_on_exit" ]; then
      aerospace workspace "$restore_on_exit" 2>/dev/null || :
    fi
    rmdir "$lockdir" 2>/dev/null || :
  ' EXIT INT TERM

  target="$1"
  current=$(aerospace list-workspaces --focused)
  splash="splash"

  # Belt-and-suspenders: if splash is focused when we enter, a prior run
  # ended mid-swap (e.g. SIGKILL between `aerospace workspace splash` and
  # the final focus restore). Swapping against splash's (empty) contents
  # would smear an unrelated workspace into emptiness. Bail instead.
  if [ "$current" = "$splash" ]; then
    return 0
  fi

  if [ "$current" = "$target" ]; then
    return 0
  fi

  # Capture both window-id lists up front so the two sets stay identifiable
  # even after they temporarily pile up on the target — no scratch workspace
  # needed (which would flash in the menu bar mid-swap).
  source_wids=$(aerospace list-windows --workspace "$current" --format '%{window-id}')
  target_wids=$(aerospace list-windows --workspace "$target" --format '%{window-id}')

  # Snapshot each workspace's root layout before the moves so we can ship it
  # along with the windows. `%{window-parent-container-layout}` on the first
  # window of a flat workspace is the root layout — accurate for the common
  # case; nested trees fall back to whatever their first window's parent is.
  source_layout=$(aerospace list-windows --workspace "$current" --format '%{window-parent-container-layout}' | head -n1)
  target_layout=$(aerospace list-windows --workspace "$target" --format '%{window-parent-container-layout}' | head -n1)

  # Arm the exit-trap with the final destination BEFORE any of the
  # subsequent aerospace calls that could trip `set -e` (a move against a
  # just-closed window, a layout call on a stale container, etc.). The trap
  # is the only thing that restores focus, so if we set the target late and
  # anything fails in between, focus would fall back to `current` and the
  # --focus-follows-workspace contract breaks.
  #
  # With --focus-follows-workspace we snapshot the currently focused
  # window-id and let the trap focus it directly — after the swap that
  # window lives on target, and `aerospace focus --window-id` brings its
  # workspace forward, so the user lands back on the exact same window.
  if [ "$focus_follows" -eq 1 ]; then
    restore_window_on_exit=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null || :)
  else
    restore_on_exit="$current"
  fi

  # Hide the bulk moves behind an empty "splash" workspace: focus it before
  # the moves so neither source nor target is on-screen while windows get
  # shuffled around. `--window-id` on the move commands keeps them from
  # stealing focus back. One focus change at the end lands on the final
  # workspace instead of N flickering ones during the moves.
  aerospace workspace "$splash"

  # Individual aerospace calls are tolerated (`|| :`) so a stale window-id
  # doesn't abort the whole swap and leave things half-moved.
  for wid in $source_wids; do
    aerospace move-node-to-workspace --window-id "$wid" "$target" 2>/dev/null || :
  done
  for wid in $target_wids; do
    aerospace move-node-to-workspace --window-id "$wid" "$current" 2>/dev/null || :
  done

  # Reapply layouts via any window that just landed on each workspace — the
  # source's windows are now on target (so target adopts source's layout),
  # and vice versa. Empty originals have no layout to restore.
  if [ -n "$source_layout" ]; then
    first_source=$(echo "$source_wids" | head -n1)
    if [ -n "$first_source" ]; then
      aerospace layout --window-id "$first_source" "$source_layout" 2>/dev/null || :
    fi
  fi
  if [ -n "$target_layout" ]; then
    first_target=$(echo "$target_wids" | head -n1)
    if [ -n "$first_target" ]; then
      aerospace layout --window-id "$first_target" "$target_layout" 2>/dev/null || :
    fi
  fi
}

cmd_preset() {
  main_size=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
    help | -h | --help | "")
      cmd_preset_help
      return
      ;;
    --main-size)
      main_size="${2:-}"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "orbit preset: unknown option '$1'" >&2
      cmd_preset_help >&2
      return 2
      ;;
    *)
      break
      ;;
    esac
  done

  case "${1:-}" in
  "")
    cmd_preset_help
    return
    ;;
  2-col-left) cmd_preset_2 left ;;
  2-col-right) cmd_preset_2 right ;;
  2-row-top) cmd_preset_2 top ;;
  2-row-bottom) cmd_preset_2 bottom ;;
  3-col-left) cmd_preset_3 left ;;
  3-col-middle) cmd_preset_3_middle col ;;
  3-col-right) cmd_preset_3 right ;;
  3-row-top) cmd_preset_3 top ;;
  3-row-middle) cmd_preset_3_middle row ;;
  3-row-bottom) cmd_preset_3 bottom ;;
  *)
    echo "orbit preset: unknown preset '$1'" >&2
    cmd_preset_help >&2
    return 2
    ;;
  esac
}

cmd_preset_2() {
  # $1 is the side where the main window lives: left, right, top, or bottom.
  # The stack of non-main windows ends up on the opposite side. top/bottom are
  # normalized to aerospace's up/down direction names for move/join-with.
  main_side="$1"
  case "$main_side" in
  left) stack_side=right top_layout=h_tiles main_dim=width ;;
  right) stack_side=left top_layout=h_tiles main_dim=width ;;
  top) stack_side=down top_layout=v_tiles main_dim=height main_side=up ;;
  bottom) stack_side=up top_layout=v_tiles main_dim=height main_side=down ;;
  esac

  main_id=$(aerospace list-windows --focused --format '%{window-id}')

  aerospace flatten-workspace-tree
  aerospace focus --window-id "$main_id"
  aerospace layout "$top_layout" 2>/dev/null || :

  # Push main to the chosen edge of the top-level container.
  while aerospace move --boundaries-action fail "$main_side" 2>/dev/null; do :; done

  # Build the nested stack container by navigating with focus/move rather than
  # trusting list-windows to return tree order. Skip if there are fewer than
  # two non-main windows (nothing to stack).
  total=$(aerospace list-windows --workspace focused --count)
  if [ "$total" -ge 3 ]; then
    # Focus the stack_side-most window (furthest from main).
    while aerospace focus --boundaries-action fail "$stack_side" 2>/dev/null; do :; done
    # Wrap it with its main_side neighbor into a new container whose layout
    # is opposite to the top-level — i.e., the stack container.
    aerospace join-with "$main_side"
    # Pull each remaining non-main window into the container: step toward main
    # by focus, then push the window back toward stack_side. Stop once focus
    # reaches the main window.
    while aerospace focus --boundaries-action fail "$main_side" 2>/dev/null; do
      current_id=$(aerospace list-windows --focused --format '%{window-id}')
      [ "$current_id" = "$main_id" ] && break
      aerospace move "$stack_side"
    done
  fi

  aerospace focus --window-id "$main_id"
  aerospace balance-sizes

  if [ -n "$main_size" ]; then
    aerospace resize "$main_dim" "$main_size" 2>/dev/null || :
  fi
}

cmd_preset_3() {
  # $1 is the side where the main window lives: left, right, top, or bottom.
  # Builds a 3-slot layout: main on one side, with the remaining windows
  # split roughly in half between two perpendicular stacks on the opposite
  # side. top/bottom are normalized to aerospace's up/down for move/focus.
  #
  # $2 may be `defer-resize`, in which case the `--main-size` resize is
  # skipped and the caller is responsible for applying it — used by
  # `cmd_preset_3_middle` so the resize lands on main's final slot instead
  # of its build-time slot (which could be discarded by a container transit
  # or mislaid by a sibling swap).
  main_side="$1"
  defer_resize="${2:-}"
  case "$main_side" in
  left) stack_side=right top_layout=h_tiles main_dim=width ;;
  right) stack_side=left top_layout=h_tiles main_dim=width ;;
  top) stack_side=down top_layout=v_tiles main_dim=height main_side=up ;;
  bottom) stack_side=up top_layout=v_tiles main_dim=height main_side=down ;;
  esac

  main_id=$(aerospace list-windows --focused --format '%{window-id}')

  aerospace flatten-workspace-tree
  aerospace focus --window-id "$main_id"
  aerospace layout "$top_layout" 2>/dev/null || :

  # Push main to the chosen edge of the top-level container.
  while aerospace move --boundaries-action fail "$main_side" 2>/dev/null; do :; done

  total=$(aerospace list-windows --workspace focused --count)
  non_main=$((total - 1))
  # Split the non-main windows between two stack-side slots. The
  # stack_side-most (outer) slot gets ceil(non_main / 2); the inner slot
  # gets the rest.
  outer_count=$(((non_main + 1) / 2))
  inner_count=$((non_main - outer_count))

  # Only wrap a slot in a perpendicular container when it'll hold more than
  # one window. A single-window slot is already its own top-level entry, and
  # `join-with` would fold it into a neighbor — collapsing 3 slots into 2.
  if [ "$outer_count" -ge 2 ]; then
    while aerospace focus --boundaries-action fail "$stack_side" 2>/dev/null; do :; done
    aerospace join-with "$main_side"
    pulled=2
    while [ "$pulled" -lt "$outer_count" ]; do
      aerospace focus --boundaries-action fail "$main_side" 2>/dev/null || break
      aerospace move "$stack_side"
      pulled=$((pulled + 1))
    done
  fi

  if [ "$inner_count" -ge 2 ]; then
    aerospace focus --window-id "$main_id"
    i=0
    while [ "$i" -lt "$inner_count" ]; do
      aerospace focus --boundaries-action fail "$stack_side" 2>/dev/null || break
      i=$((i + 1))
    done
    aerospace join-with "$main_side"
    pulled=2
    while [ "$pulled" -lt "$inner_count" ]; do
      aerospace focus --boundaries-action fail "$main_side" 2>/dev/null || break
      current_id=$(aerospace list-windows --focused --format '%{window-id}')
      [ "$current_id" = "$main_id" ] && break
      aerospace move "$stack_side"
      pulled=$((pulled + 1))
    done
  fi

  aerospace focus --window-id "$main_id"
  aerospace balance-sizes

  if [ "$defer_resize" != defer-resize ] && [ -n "$main_size" ]; then
    aerospace resize "$main_dim" "$main_size" 2>/dev/null || :
  fi
}

cmd_preset_3_middle() {
  # $1 is col or row. Builds `3-col-left` or `3-row-top` then shifts main
  # toward stack_side until it lands in the middle slot. The number of
  # moves depends on what sits to the stack side of main:
  #   inner_count >= 2  the inner slot is a perpendicular container —
  #                     main needs two moves to transit it (in, then out).
  #   inner_count == 1  the inner slot is a bare window — one swap lands
  #                     main in the middle.
  #   inner_count == 0  there's no inner slot (≤2 windows total) and no
  #                     meaningful middle; leave main where it is.
  # `--main-size` is deferred so it applies to main's final slot.
  case "$1" in
  col) cmd_preset_3 left defer-resize ;;
  row) cmd_preset_3 top defer-resize ;;
  esac
  if [ "$inner_count" -ge 2 ]; then
    aerospace move "$stack_side"
    aerospace move "$stack_side"
  elif [ "$inner_count" -ge 1 ]; then
    aerospace move "$stack_side"
  fi
  if [ -n "$main_size" ]; then
    aerospace resize "$main_dim" "$main_size" 2>/dev/null || :
  fi
}

cmd_move_workspace_to_secondary_help() {
  cat <<'EOF'
Usage: orbit move-workspace-to-secondary-monitor <workspace> [workspace...]

For each given workspace: pin it to the secondary monitor, flatten its
window tree, and set its layout to `accordion horizontal`. Empty
workspaces are pinned but have no layout applied — aerospace rejects
`layout` without a window to hang it on and falls back to
`default-root-container-layout` once a window arrives.

No focus change: `move-workspace-to-monitor` and `flatten-workspace-tree`
take `--workspace`, and `layout` is targeted via `--window-id`.
EOF
}

cmd_move_workspace_to_secondary() {
  case "${1:-}" in
  help | -h | --help | "")
    cmd_move_workspace_to_secondary_help
    return
    ;;
  esac

  # `move-workspace-to-monitor` is tolerated so the other setup still runs
  # on single-monitor setups (the secondary pattern just won't match).
  for ws in "$@"; do
    aerospace move-workspace-to-monitor --workspace "$ws" secondary 2>/dev/null || :
    aerospace flatten-workspace-tree --workspace "$ws"
    wid=$(aerospace list-windows --workspace "$ws" --format '%{window-id}' | head -n1)
    if [ -n "$wid" ]; then
      aerospace layout --window-id "$wid" accordion horizontal
    fi
  done
}

cmd_force_restart_help() {
  cat <<'EOF'
Usage: orbit force-restart

Kill every aerospace-related process — the GUI server and any stuck CLI
invocations — then relaunch AeroSpace. Use when the server stops
responding and dozens of `aerospace focus/workspace` CLI calls pile up
blocked on IPC.
EOF
}

cmd_force_restart() {
  case "${1:-}" in
  help | -h | --help)
    cmd_force_restart_help
    return
    ;;
  esac

  # `-x` matches the exact command name (case-sensitive) so we only reach
  # the GUI server (`AeroSpace`) and the CLI (`aerospace`) without touching
  # unrelated processes like SwipeAeroSpace.
  cmd_cleanup
  pkill -9 -x AeroSpace 2>/dev/null || :
  sleep 0.5
  open -a AeroSpace
}

cmd_cleanup_help() {
  cat <<'EOF'
Usage: orbit cleanup

Kill every stuck `aerospace` CLI process. Leaves the `AeroSpace` GUI
server running — use `orbit force-restart` if the server itself is
wedged.
EOF
}

cmd_cleanup() {
  case "${1:-}" in
  help | -h | --help)
    cmd_cleanup_help
    return
    ;;
  esac

  pkill -9 -x aerospace 2>/dev/null || :
}

case "${1:-help}" in
open)
  shift
  cmd_open "$@"
  ;;
focus)
  shift
  cmd_focus "$@"
  ;;
move)
  shift
  cmd_move "$@"
  ;;
swap)
  shift
  cmd_swap "$@"
  ;;
swap-or-move-node-to-workspace)
  shift
  cmd_swap_or_move "$@"
  ;;
move-workspace)
  shift
  cmd_move_workspace "$@"
  ;;
preset)
  shift
  cmd_preset "$@"
  ;;
move-workspace-to-secondary-monitor)
  shift
  cmd_move_workspace_to_secondary "$@"
  ;;
force-restart)
  shift
  cmd_force_restart "$@"
  ;;
cleanup)
  shift
  cmd_cleanup "$@"
  ;;
help | -h | --help) cmd_help ;;
*) exec aerospace "$@" ;;
esac
