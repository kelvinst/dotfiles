#!/bin/sh
# orbit — our aerospace wrapper with more commands

set -eu

cmd_help() {
  cat <<'EOF'
orbit — aerospace helper.

Usage: orbit <command> [args...]

Commands:
  open     Focus or spawn an app window by bundle-id.
  focus    A wrapper around `aerospace focus` that adds more options to it.
  move     A wrapper around `aerospace move` that adds more options to it.
  swap-or-move-node-to-workspace
           Swap the focused window with its neighbor; at the workspace edge,
           move the window to the adjacent workspace instead.
  help     Show this help.

Run `orbit <command> help` for details on a command.

Any other command is forwarded to `aerospace` verbatim, so
`orbit reload-config` runs `aerospace reload-config`.
EOF
}

cmd_open_help() {
  cat <<'EOF'
Usage: orbit open [-a|--all] <bundle-id>

Focus an app window in the focused aerospace workspace, or spawn a new window
here. With -a/--all, focus an existing window in any workspace.
EOF
}

cmd_focus_help() {
  cat <<'EOF'
Usage: orbit focus dfs-first
       orbit focus dfs-last
       orbit focus [args...]

A wrapper around `aerospace focus` that adds more options to it.

Added options:
  --boundaries-action sibling-workspace
        On focus failure, focus the adjacent workspace instead
        (right/down → next, left/up → prev).

Added subcommands:
  dfs-first   Focus the first window (`--dfs-index 0`).
  dfs-last    Focus the last window on the focused workspace.
EOF
}

cmd_move_help() {
  cat <<'EOF'
Usage: orbit move [args...]

A wrapper around `aerospace move` that adds more options to it.

Added options:
  --boundaries-action sibling-workspace
        On move failure, move the window to the adjacent workspace instead
        (right/down → next, left/up → prev).
EOF
}

cmd_swap_or_move_help() {
  cat <<'EOF'
Usage: orbit swap-or-move-node-to-workspace [args...] <direction>

Run `aerospace swap` (without `--wrap-around`) with the given args. If the
swap fails because the window is at the workspace boundary, fall back to
`orbit move --boundaries-action sibling-workspace <direction>` so the window
is sent to the adjacent workspace instead.
EOF
}

cmd_open() {
  case "${1:-}" in
  help | -h | --help)
    cmd_open_help
    return
    ;;
  esac

  any_workspace=0
  case "${1:-}" in
  -a | --all)
    any_workspace=1
    shift
    ;;
  esac

  bundle_id="$1"

  if [ "$any_workspace" -eq 1 ]; then
    window_id=$(aerospace list-windows --all --format '%{window-id} %{app-bundle-id}' 2>/dev/null |
      awk -v id="$bundle_id" '$2 == id {print $1; exit}')
  else
    window_id=$(aerospace list-windows --workspace focused --app-bundle-id "$bundle_id" --format '%{window-id}' 2>/dev/null | head -n1)
  fi

  if [ -n "$window_id" ]; then
    aerospace focus --window-id "$window_id"
  elif [ "$bundle_id" = "com.apple.finder" ]; then
    osascript -e 'tell application "Finder"
                      make new Finder window
                      activate
                  end tell'
  elif [ "$bundle_id" = "net.kovidgoyal.kitty" ]; then
    socket=$(ls -t /tmp/kitty-* 2>/dev/null | head -n1)
    kitten @ --to "unix:$socket" launch --type=os-window >/dev/null
  elif [ "$bundle_id" = "com.apple.Notes" ]; then
    open -b com.apple.Notes
  elif osascript -e "tell application id \"$bundle_id\" to make new window" >/dev/null 2>&1; then
    osascript -e "tell application id \"$bundle_id\" to activate"
  else
    open -b "$bundle_id"
  fi
}

cmd_focus() {
  case "${1:-}" in
  help | -h | --help)
    cmd_focus_help
    return
    ;;
  dfs-first)
    aerospace focus --dfs-index 0
    return
    ;;
  dfs-last)
    last=$(($(aerospace list-windows --workspace focused --format '%{window-id}' | wc -l) - 1))
    aerospace focus --dfs-index "$last"
    return
    ;;
  esac

  # Extend `aerospace focus` with a custom `--boundaries-action
  # sibling-workspace` value: strip that flag and, on focus failure,
  # switch to the adjacent workspace (right/down → next, left/up → prev).
  # Any other invocation is forwarded verbatim.
  sibling=0
  count=$#
  idx=0
  while [ "$idx" -lt "$count" ]; do
    if [ "$1" = "--boundaries-action" ] && [ "${2:-}" = "sibling-workspace" ]; then
      sibling=1
      shift 2
      idx=$((idx + 2))
      continue
    fi
    arg="$1"
    shift
    set -- "$@" "$arg"
    idx=$((idx + 1))
  done

  if [ "$sibling" -eq 0 ]; then
    exec aerospace focus "$@"
  fi

  # `--boundaries all-monitors-outer-frame` would let focus cross monitors at
  # the workspace edge, so the boundary never fails and the sibling-workspace
  # fallback never fires. Reject the combination explicitly.
  prev=""
  for arg in "$@"; do
    if [ "$prev" = "--boundaries" ] && [ "$arg" = "all-monitors-outer-frame" ]; then
      echo "orbit focus: --boundaries all-monitors-outer-frame is incompatible with --boundaries-action sibling-workspace" >&2
      return 2
    fi
    prev="$arg"
  done

  if aerospace focus --boundaries-action fail "$@" 2>/dev/null; then
    return
  fi
  direction=""
  for arg in "$@"; do direction="$arg"; done
  case "$direction" in
  right | down)
    aerospace workspace --wrap-around --no-stdin next
    cmd_focus dfs-first
    ;;
  left | up)
    aerospace workspace --wrap-around --no-stdin prev
    cmd_focus dfs-last
    ;;
  *) return 1 ;;
  esac
}

cmd_move() {
  case "${1:-}" in
  help | -h | --help)
    cmd_move_help
    return
    ;;
  esac

  # Extend `aerospace move` with a custom `--boundaries-action
  # sibling-workspace` value: strip that flag and, on move failure,
  # send the window to the adjacent workspace (right/down → next, left/up →
  # prev). Any other invocation is forwarded verbatim.
  sibling=0
  count=$#
  idx=0
  while [ "$idx" -lt "$count" ]; do
    if [ "$1" = "--boundaries-action" ] && [ "${2:-}" = "sibling-workspace" ]; then
      sibling=1
      shift 2
      idx=$((idx + 2))
      continue
    fi
    arg="$1"
    shift
    set -- "$@" "$arg"
    idx=$((idx + 1))
  done

  if [ "$sibling" -eq 0 ]; then
    exec aerospace move "$@"
  fi

  # `--boundaries all-monitors-outer-frame` would let move cross monitors at
  # the workspace edge, so the boundary never fails and the sibling-workspace
  # fallback never fires. Reject the combination explicitly.
  prev=""
  for arg in "$@"; do
    if [ "$prev" = "--boundaries" ] && [ "$arg" = "all-monitors-outer-frame" ]; then
      echo "orbit move: --boundaries all-monitors-outer-frame is incompatible with --boundaries-action sibling-workspace" >&2
      return 2
    fi
    prev="$arg"
  done

  if aerospace move --boundaries-action fail "$@" 2>/dev/null; then
    return
  fi
  direction=""
  for arg in "$@"; do direction="$arg"; done
  case "$direction" in
  right | down)
    aerospace move-node-to-workspace --wrap-around --focus-follows-window --no-stdin next
    while aerospace move --boundaries-action fail left 2>/dev/null; do :; done
    ;;
  left | up)
    aerospace move-node-to-workspace --wrap-around --focus-follows-window --no-stdin prev
    while aerospace move --boundaries-action fail right 2>/dev/null; do :; done
    ;;
  *) return 1 ;;
  esac
}

cmd_swap_or_move() {
  case "${1:-}" in
  help | -h | --help)
    cmd_swap_or_move_help
    return
    ;;
  esac

  if aerospace swap "$@" 2>/dev/null; then
    return
  fi
  direction=""
  for arg in "$@"; do direction="$arg"; done
  cmd_move --boundaries-action sibling-workspace "$direction"
}

case "${1:-help}" in
open)
  shift
  cmd_open "$@"
  ;;
focus)
  shift
  cmd_focus "$@"
  ;;
move)
  shift
  cmd_move "$@"
  ;;
swap-or-move-node-to-workspace)
  shift
  cmd_swap_or_move "$@"
  ;;
help | -h | --help) cmd_help ;;
*) exec aerospace "$@" ;;
esac
