#!/bin/sh
# Focus an app in the current aerospace workspace, or spawn a new window here.
#
# Usage: aerospace-open-app <bundle-id>

set -eu

bundle_id="$1"

window_id=$(aerospace list-windows --workspace focused --app-bundle-id "$bundle_id" --format '%{window-id}' 2>/dev/null | head -n1)

if [ -n "$window_id" ]; then
  aerospace focus --window-id "$window_id"
elif [ "$bundle_id" = "com.apple.finder" ]; then
  # Finder uses a non-standard AppleScript verb and rejects `tell` until
  # activated.
  osascript -e 'tell application "Finder"
                    make new Finder window
                    activate
                end tell'
elif [ "$bundle_id" = "net.kovidgoyal.kitty" ]; then
  # Kitty doesn't respond to AppleScript; `open -n` spawns a new OS window.
  open -nb "$bundle_id"
elif osascript -e "tell application id \"$bundle_id\" to make new window" >/dev/null 2>&1; then
  osascript -e "tell application id \"$bundle_id\" to activate"
else
  open -b "$bundle_id"
fi
